
# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Neon PostgreSQL ──────────────────────────────────────────
# Replace with your actual Neon DB URL (keep this safe!)
DATABASE_URL=postgresql://neondb_owner:npg_V6hK0HpDPUEe@ep-purple-flower-aq7823wi-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=super_secure_jwt_secret_key_for_shopwave_32_chars_min
JWT_EXPIRES_IN=7d

# ── File Upload (Cloudinary) ─────────────────────────────────
# (You can keep these as-is for now, or add real ones)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_FILE_SIZE_MB=10

# ── Frontend URL (CORS) ───────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Backend public URL (used for SSLCommerz/bKash callback URLs) ─────────────
# In development: use ngrok → ngrok http 5000 → copy the https URL here
# In production: use your real domain e.g. https://api.yourshop.com
SERVER_URL=http://localhost:5000

# ── Payment Mode ─────────────────────────────────────────────
# Set to "true" to enable mock payments (no real gateway credentials needed)
PAYMENT_MOCK_MODE=false

# ── bKash API ────────────────────────────────────────────────
# Set BKASH_MOCK_MODE=true to use the mock payment portal (no real credentials needed)
# Set BKASH_MOCK_MODE=false and fill in real credentials to go live
BKASH_MOCK_MODE=true
BKASH_IS_LIVE=false
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password

# ── SSLCommerz ───────────────────────────────────────────────
SSLCOMMERZ_IS_LIVE=false
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com
SSLCOMMERZ_STORE_ID=cozyg69fc8a1080dbb
SSLCOMMERZ_STORE_PASSWORD=cozyg69fc8a1080dbb@ssl

# ── Development Options ───────────────────────────────────────
DISABLE_RATE_LIMIT=true
